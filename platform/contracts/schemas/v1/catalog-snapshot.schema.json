{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/capability-platform/v1/catalog-snapshot.schema.json",
  "title": "Immutable Machine Catalog Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "revision", "catalog_scope", "packages", "templates", "extensions", "generators", "sdks", "permission_catalog", "feature_block_catalog", "schema_catalog", "snapshot_sha256"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "revision": { "$ref": "common.schema.json#/$defs/identifier" },
    "catalog_scope": { "$ref": "common.schema.json#/$defs/catalogVisibility" },
    "packages": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/catalogItem" } },
    "templates": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/catalogItem" } },
    "extensions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/extensionCatalogItem" } },
    "generators": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/toolCatalogItem" } },
    "sdks": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/toolCatalogItem" } },
    "permission_catalog": { "$ref": "#/$defs/versionedInput" },
    "feature_block_catalog": { "$ref": "#/$defs/versionedInput" },
    "schema_catalog": { "$ref": "#/$defs/versionedInput" },
    "snapshot_sha256": { "$ref": "common.schema.json#/$defs/sha256" }
  },
  "$defs": {
    "versionedInput": {
      "type": "object", "additionalProperties": false, "required": ["version", "sha256"],
      "properties": { "version": { "$ref": "common.schema.json#/$defs/semver" }, "sha256": { "$ref": "common.schema.json#/$defs/sha256" } }
    },
    "catalogItem": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "manifest_sha256", "content_tree_sha256", "availability", "dependencies", "conflicts", "supported_targets", "supported_delivery_modes", "backend_capabilities"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/identifier" },
        "version": { "$ref": "common.schema.json#/$defs/semver" },
        "manifest_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "content_tree_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "availability": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/availability" } },
        "dependencies": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/packageRequirement" } },
        "conflicts": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/packageRequirement" } },
        "supported_targets": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/target" } },
        "supported_delivery_modes": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/deliveryMode" } }
        ,"backend_capabilities": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/identifier" } }
      }
    },
    "toolCatalogItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_id", "version", "manifest_sha256", "content_tree_sha256", "protocol", "execution", "supported_targets", "supported_delivery_modes", "supported_environments"],
      "properties": {
        "tool_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "version": { "$ref": "common.schema.json#/$defs/semver" },
        "manifest_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "content_tree_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "protocol": { "$ref": "#/$defs/toolProtocol" },
        "execution": { "$ref": "#/$defs/toolExecution" },
        "supported_targets": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/target" } },
        "supported_delivery_modes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/deliveryMode" } },
        "supported_environments": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/environment" } }
      }
    },
    "extensionCatalogItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension_id", "version", "product_code", "manifest_path", "manifest_sha256", "content_tree_sha256", "supported_targets", "supported_delivery_modes", "supported_environments", "data_namespace"],
      "properties": {
        "extension_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "version": { "$ref": "common.schema.json#/$defs/semver" },
        "product_code": { "$ref": "common.schema.json#/$defs/identifier" },
        "manifest_path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
        "manifest_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "content_tree_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "supported_targets": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/target" } },
        "supported_delivery_modes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/deliveryMode" } },
        "supported_environments": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/environment" } },
        "data_namespace": { "type": "string", "pattern": "^ext_[a-z][a-z0-9_]{2,62}$" }
      }
    },
    "toolProtocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/identifier" },
        "version": { "$ref": "common.schema.json#/$defs/semver" }
      }
    },
    "toolExecution": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "adapter_id"],
          "properties": {
            "mode": { "const": "builtin_adapter" },
            "adapter_id": { "$ref": "common.schema.json#/$defs/identifier" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "path", "sha256"],
          "properties": {
            "mode": { "enum": ["node", "native"] },
            "path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
            "sha256": { "$ref": "common.schema.json#/$defs/sha256" }
          }
        }
      ]
    },
    "availability": {
      "type": "object", "additionalProperties": false,
      "required": ["target", "delivery_mode", "environments", "visibility", "readiness"],
      "properties": {
        "target": { "$ref": "common.schema.json#/$defs/target" },
        "delivery_mode": { "$ref": "common.schema.json#/$defs/deliveryMode" },
        "environments": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/environment" } },
        "visibility": { "$ref": "common.schema.json#/$defs/catalogVisibility" },
        "readiness": { "$ref": "common.schema.json#/$defs/packageReadiness" }
      }
    }
  }
}
