{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/capability-platform/v1/feature-block-catalog.schema.json",
  "title": "Feature Block Machine Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_version", "blocks", "catalog_sha256"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "catalog_version": { "$ref": "common.schema.json#/$defs/semver" },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["block_id", "surface", "readiness"],
        "properties": {
          "block_id": { "$ref": "common.schema.json#/$defs/blockId" },
          "surface": { "type": "string", "enum": ["admin", "client"] },
          "readiness": { "type": "string", "enum": ["not_ready", "ready", "deprecated"] }
        }
      }
    },
    "catalog_sha256": { "$ref": "common.schema.json#/$defs/sha256" }
  }
}
