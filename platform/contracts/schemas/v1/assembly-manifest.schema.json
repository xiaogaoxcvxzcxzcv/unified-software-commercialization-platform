{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/capability-platform/v1/assembly-manifest.schema.json",
  "title": "Assembly Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "assembly_id", "run_id", "product", "blueprint", "catalog_checksum", "packages", "templates", "sdks", "outputs", "evidence", "secret_refs", "created_at", "manifest_checksum"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "assembly_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "run_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product_id", "official_tenant_id", "applications"],
      "properties": {
        "product_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "official_tenant_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "applications": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["plan_application_id", "application_id"],
            "properties": {
              "plan_application_id": { "$ref": "common.schema.json#/$defs/identifier" },
              "application_id": { "$ref": "common.schema.json#/$defs/identifier" }
            }
          }
        }
      }
    },
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blueprint_id", "version", "checksum"],
      "properties": {
        "blueprint_id": { "$ref": "common.schema.json#/$defs/blueprintId" },
        "version": { "type": "integer", "minimum": 1 },
        "checksum": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    },
    "catalog_checksum": { "$ref": "common.schema.json#/$defs/sha256" },
    "packages": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/versionedPackage" } },
    "templates": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/versionedTemplate" } },
    "sdks": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/versionedSdk" } },
    "outputs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/output" } },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
    "secret_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/secretRef" } },
    "created_at": { "type": "string", "format": "date-time" },
    "manifest_checksum": { "$ref": "common.schema.json#/$defs/sha256" }
  },
  "$defs": {
    "versionedPackage": {
      "type": "object", "additionalProperties": false, "required": ["package_id", "version", "checksum"],
      "properties": { "package_id": { "$ref": "common.schema.json#/$defs/packageId" }, "version": { "$ref": "common.schema.json#/$defs/semver" }, "checksum": { "$ref": "common.schema.json#/$defs/sha256" } }
    },
    "versionedTemplate": {
      "type": "object", "additionalProperties": false, "required": ["template_id", "version", "checksum"],
      "properties": { "template_id": { "$ref": "common.schema.json#/$defs/templateId" }, "version": { "$ref": "common.schema.json#/$defs/semver" }, "checksum": { "$ref": "common.schema.json#/$defs/sha256" } }
    },
    "versionedSdk": {
      "type": "object", "additionalProperties": false, "required": ["sdk_id", "version", "checksum"],
      "properties": { "sdk_id": { "$ref": "common.schema.json#/$defs/identifier" }, "version": { "$ref": "common.schema.json#/$defs/semver" }, "checksum": { "$ref": "common.schema.json#/$defs/sha256" } }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "ownership", "sha256", "source_id", "source_version", "source_path", "source_sha256", "render_strategy", "content_type"],
      "properties": {
        "path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
        "ownership": { "type": "string", "enum": ["generated", "integration", "custom", "forked"] },
        "sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "source_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "source_version": { "$ref": "common.schema.json#/$defs/semver" },
        "source_path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
        "source_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "render_strategy": { "$ref": "common.schema.json#/$defs/renderStrategy" },
        "content_type": { "$ref": "common.schema.json#/$defs/contentType" },
        "merge": { "$ref": "common.schema.json#/$defs/integrationMerge" }
      },
      "allOf": [
        {
          "if": { "properties": { "ownership": { "const": "integration" } }, "required": ["ownership"] },
          "then": { "required": ["merge"] }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "type", "status", "path", "sha256"],
      "properties": {
        "evidence_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "type": { "type": "string", "enum": ["contract_report", "test_report", "smoke_report", "isolation_report", "artifact"] },
        "status": { "type": "string", "enum": ["passed", "failed", "not_applicable"] },
        "path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
        "sha256": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    }
  }
}
