{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/capability-platform/v1/assembly-run.schema.json",
  "title": "Assembly Run",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "plan_id", "plan_checksum", "idempotency_key_digest", "output_target_ref", "status", "steps", "diagnostic_ids", "recovery", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "run_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "plan_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "plan_checksum": { "$ref": "common.schema.json#/$defs/sha256" },
    "idempotency_key_digest": { "$ref": "common.schema.json#/$defs/sha256" },
    "output_target_ref": { "$ref": "common.schema.json#/$defs/identifier" },
    "status": { "type": "string", "enum": ["planned", "provisioning", "generating", "validating", "completed", "failed", "rolling_back", "rolled_back"] },
    "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } },
    "current_step_id": { "oneOf": [{ "$ref": "common.schema.json#/$defs/identifier" }, { "type": "null" }] },
    "diagnostic_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/identifier" } },
    "manifest_path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
    "lock_path": { "$ref": "common.schema.json#/$defs/safeRelativePath" },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retryable", "rollback_required"],
      "properties": {
        "retryable": { "type": "boolean" },
        "rollback_required": { "type": "boolean" },
        "resume_from_step_id": { "$ref": "common.schema.json#/$defs/identifier" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
      "then": { "required": ["manifest_path", "lock_path", "completed_at"], "properties": { "diagnostic_ids": { "maxItems": 0 } } }
    },
    {
      "if": { "properties": { "status": { "enum": ["failed", "rolled_back"] } }, "required": ["status"] },
      "then": { "required": ["completed_at"], "properties": { "diagnostic_ids": { "minItems": 1 } } }
    }
  ],
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "kind", "status", "attempt", "compensation_status"],
      "properties": {
        "step_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "kind": { "type": "string", "enum": ["provision", "enable_capability", "generate", "validate", "commit", "rollback"] },
        "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "compensated", "skipped"] },
        "attempt": { "type": "integer", "minimum": 0 },
        "compensation_status": { "type": "string", "enum": ["not_required", "pending", "completed", "failed"] },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "diagnostic_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/identifier" } }
      }
    }
  }
}
