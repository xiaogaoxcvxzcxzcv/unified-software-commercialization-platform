{
  "schema_version": "1.0.0",
  "package_id": "package.account",
  "version": "1.0.0",
  "name": "Unified account",
  "user_value": "Reusable account, session, profile, and product admission capabilities.",
  "lifecycle_status": "contracted",
  "availability": [],
  "dependencies": [],
  "conflicts": [],
