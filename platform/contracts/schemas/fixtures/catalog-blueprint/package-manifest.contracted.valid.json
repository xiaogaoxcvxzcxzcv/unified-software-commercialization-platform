  "public_api_operations": ["registerUser", "createUserSession", "refreshUserSession", "revokeUserSession", "getCurrentUser", "updateCurrentUserProfile", "evaluateProductUserAccess"],
  "sdk_modules": ["sdk.account"],
  "sdk_methods": ["registerUser", "createUserSession", "refreshUserSession", "revokeUserSession", "getCurrentUser", "updateCurrentUserProfile", "evaluateProductUserAccess"],
  "stable_errors": ["IDENTITY_INVALID_CREDENTIALS", "IDENTITY_ACCOUNT_DISABLED", "PRODUCT_USER_ACCESS_SUSPENDED", "TENANT_USER_ACCESS_SUSPENDED", "ENTITLEMENT_REQUIRED"],
  "config_schema_path": "platform/contracts/packages/package.account/1.0.0/config.schema.json",
  "secret_refs": [],
  "provider_requirements": ["notification.security"],
  "optional_provider_requirements": ["identity.external.oidc", "identity.external.wechat"],
  "generated_outputs": [{ "path": "src/generated/account/routes.tsx", "ownership": "generated", "source_path": "content/account.txt", "source_sha256": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "render_strategy": "strict_template", "content_type": "text" }],
  "source_locations": ["platform/backend/internal/modules/identity", "platform/backend/internal/modules/productuseraccess", "platform/client-ui/web-react/account"],
  "extension_points": ["account.profile-slot"],
  "test_paths": ["platform/tests/account/golden-flow.test.ts"],
  "smoke_tests": ["st.account-login", "st.account-access-precedence"],
  "documentation_paths": ["docs/features/account/README.md", "docs/features/account/contract.md", "docs/features/product-user-access/contract.md"],
  "upgrade_policy": { "strategy": "compatible", "guide_path": "docs/features/account/upgrade.md" },
  "rollback_policy": { "strategy": "automatic", "guide_path": "docs/features/account/rollback.md" },
  "data_retention": [{ "data_set": "identity.user", "policy": "Retain global identity independently from product admission state.", "guide_path": "docs/features/account/data-retention.md" }],
  "content_files": [{ "path": "content/account.txt", "sha256": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "kind": "file" }],
  "content_tree_sha256": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
  "manifest_sha256": "sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
}
