{
  "name": "@capability-platform/client-ui",
  "version": "0.1.0",
  "description": "Framework-neutral state contracts, React foundations, and hosted UI bootstrap for product client surfaces.",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "README.md"],
  "exports": {
    "./contracts": { "types": "./dist/contracts/src/index.d.ts", "import": "./dist/contracts/src/index.js" },
    "./headless": { "types": "./dist/headless/src/index.d.ts", "import": "./dist/headless/src/index.js" },
    "./web-react": { "types": "./dist/web-react/src/index.d.ts", "import": "./dist/web-react/src/index.js" },
    "./hosted-web": { "types": "./dist/hosted-web/src/index.d.ts", "import": "./dist/hosted-web/src/index.js" },
    "./styles.css": "./dist/web-react/src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "test": "vitest run --configLoader runner"
  },
  "engines": { "node": ">=20" },
  "peerDependencies": {
    "@capability-platform/client-sdk": "^0.1.0",
    "react": ">=18 <20"
  },
  "devDependencies": {
    "@capability-platform/client-sdk": "file:../sdk/typescript",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "26.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
