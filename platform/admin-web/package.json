{
  "name": "commercial-platform-admin-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:https": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev-https.ps1",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build --configLoader runner",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner"
  },
  "dependencies": {
    "@tabler/icons-react": "3.44.0",
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "7.18.1",
    "recharts": "3.9.2",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "26.1.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
