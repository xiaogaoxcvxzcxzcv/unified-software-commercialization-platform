{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext.Disposable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": false,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["src/generated/packages/account/**/*.ts", "src/generated/packages/account/**/*.tsx"]
}
