PLATFORM_ENVIRONMENT=local
PLATFORM_HTTP_ADDRESS=:8080
PLATFORM_LOG_LEVEL=info
PLATFORM_DATABASE_URL=postgres://platform:change-me@127.0.0.1:5432/platform?sslmode=disable
PLATFORM_DATABASE_MAX_CONNECTIONS=20
PLATFORM_DATABASE_MIN_CONNECTIONS=2
PLATFORM_DATABASE_CONNECT_TIMEOUT=5s
PLATFORM_HEALTH_CHECK_TIMEOUT=2s
PLATFORM_HTTP_READ_HEADER_TIMEOUT=5s
PLATFORM_HTTP_READ_TIMEOUT=15s
PLATFORM_HTTP_WRITE_TIMEOUT=30s
PLATFORM_HTTP_IDLE_TIMEOUT=60s
PLATFORM_SHUTDOWN_TIMEOUT=15s
