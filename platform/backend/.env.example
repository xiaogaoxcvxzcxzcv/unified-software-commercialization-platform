PLATFORM_ENVIRONMENT=local
PLATFORM_HTTP_ADDRESS=:8080
PLATFORM_LOG_LEVEL=info
PLATFORM_DATABASE_URL=postgres://platform:change-me@127.0.0.1:5432/platform?sslmode=disable
PLATFORM_DATABASE_MAX_CONNECTIONS=20
PLATFORM_DATABASE_MIN_CONNECTIONS=2
PLATFORM_DATABASE_CONNECT_TIMEOUT=5s
PLATFORM_HEALTH_CHECK_TIMEOUT=2s
PLATFORM_HTTP_READ_HEADER_TIMEOUT=5s
PLATFORM_HTTP_READ_TIMEOUT=15s
PLATFORM_HTTP_WRITE_TIMEOUT=30s
PLATFORM_HTTP_IDLE_TIMEOUT=60s
PLATFORM_SHUTDOWN_TIMEOUT=15s
PLATFORM_ADMIN_TOKEN_PEPPER=replace-with-at-least-32-random-bytes
PLATFORM_ADMIN_ALLOWED_ORIGINS=https://127.0.0.1:5174
PLATFORM_ADMIN_ACCESS_TTL=15m
PLATFORM_ADMIN_REFRESH_TTL=168h
PLATFORM_ADMIN_LOGIN_WINDOW=15m
PLATFORM_ADMIN_LOGIN_BLOCK_DURATION=15m
PLATFORM_ADMIN_LOGIN_MAXIMUM_ATTEMPTS=5
PLATFORM_ADMIN_BCRYPT_COST=12
PLATFORM_ADMIN_BEARER_ENABLED=false
PLATFORM_ASSEMBLY_SCHEMA_DIRECTORY=../contracts/schemas/v1
PLATFORM_ASSEMBLY_CAPABILITY_PACKAGE_ROOT=../capability-packages
PLATFORM_ASSEMBLY_TEMPLATE_ROOT=../templates
PLATFORM_ASSEMBLY_GENERATOR_TOOL_ROOT=../tools/generators
PLATFORM_ASSEMBLY_SDK_TOOL_ROOT=../tools/sdks
PLATFORM_ASSEMBLY_FEATURE_BLOCK_CATALOG=../contracts/catalogs/v1/feature-blocks.json
PLATFORM_ASSEMBLY_OUTPUT_TARGETS=[{"ref":"workspace.default","environment":"development","display_name":"Local development workspace","summary":"Server-managed local source and evidence output","is_default":true,"target_root":"D:/replace-with-authorized-software-root","artifact_root":"D:/replace-with-authorized-artifact-root"}]
